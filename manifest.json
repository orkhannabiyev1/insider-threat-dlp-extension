{
  "manifest_version": 3,
  "name": "Insider Threat Monitor (DLP)",
  "version": "1.0.0",
  "description": "Gmail ΟΦz…ôrind…ôn gΟΕnd…ôril…ôn kart nΟΕmr…ôl…ôrini a≈ükar edir, gΟΕnd…ôrilm…ôd…ôn …ôvv…ôl korlayΡ±r v…ô SOC-a s…ôssiz alert gΟΕnd…ôrir.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mail.google.com/*",
